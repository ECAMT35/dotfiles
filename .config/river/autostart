#!/bin/sh
# @author ECAMT

pkill -x dam 2>/dev/null
${HOME}/.config/dam/init | dam >/dev/null 2>&1 &

wlr-randr --output "$(wlr-randr | head -n1 | cut -d' ' -f1)" --scale 1.5

pkill -x swaybg 2>/dev/null
swaybg -i "$HOME/Pictures/Wallpaper/desktop.png" -m fill >/dev/null 2>&1 &

pkill -x swayidle 2>/dev/null
swayidle -w \
    timeout 600 'swaylock -f' \
    timeout 900 'wlopm --off \*' \
    resume 'wlopm --on \*' \
    before-sleep 'swaylock -f -c 000000' >/dev/null 2>&1 &

pkill -x fcitx5 2>/dev/null
fcitx5 -d

pkill -f "wl-paste --watch cliphist store" 2>/dev/null
wl-paste --watch cliphist store &

pkill -x fnott 2>/dev/null
fnott >/dev/null 2>&1 &

